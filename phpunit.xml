<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_DEBUG" value="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>

        <!-- Sécurité : rounds réduits pour accélérer les tests -->
        <env name="BCRYPT_ROUNDS" value="4"/>

        <!-- Base de données : PostgreSQL dédié aux tests -->
        <!-- Créer manuellement : createdb omnyrestore_test -->
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="5432"/>
        <env name="DB_DATABASE" value="omnyrestore_test"/>
        <env name="DB_USERNAME" value="postgres"/>
        <env name="DB_PASSWORD" value="postgres"/>
        <env name="DB_URL" value=""/>

        <!-- Services désactivés en test -->
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="MAIL_MAILER" value="array"/>

        <!-- Stockage local pour éviter les appels S3 en test -->
        <env name="FILESYSTEM_DISK" value="local"/>
        <env name="MEDIA_DISK" value="local"/>
        <env name="DELIVERY_DISK" value="local"/>

        <!-- Stripe : clés factices (pas d'appels réels) -->
        <env name="STRIPE_KEY" value="pk_test_fake"/>
        <env name="STRIPE_SECRET" value="sk_test_fake"/>
        <env name="STRIPE_WEBHOOK_SECRET" value="whsec_fake"/>

        <!-- OpenAI : clé factice (pas d'appels réels) -->
        <env name="OPENAI_API_KEY" value="sk-fake"/>

        <!-- Désactiver les packages de monitoring optionnels -->
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <env name="HORIZON_DARK_MODE" value="false"/>
    </php>
</phpunit>
