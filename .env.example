# =============================================================================
# OmnyRestore — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file — it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME="OmnyRestore"
APP_ENV=local                   # local | staging | production
APP_KEY=                        # Generated by: php artisan key:generate
APP_DEBUG=true                  # Set to false in production
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                 # debug | info | warning | error | critical

# -----------------------------------------------------------------------------
# DATABASE — PostgreSQL 16
# -----------------------------------------------------------------------------
# We use PostgreSQL (not SQLite) for its UUID support, JSON columns, and FK robustness
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=omnyrestore
DB_USERNAME=postgres
DB_PASSWORD=

# -----------------------------------------------------------------------------
# SESSION
# -----------------------------------------------------------------------------
SESSION_DRIVER=redis            # Use Redis for session storage in production
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------------------------------------
# QUEUES — Laravel Horizon (Redis)
# -----------------------------------------------------------------------------
# Horizon requires Redis. In local dev, you can use 'database' as fallback.
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

# -----------------------------------------------------------------------------
# CACHE — Redis
# -----------------------------------------------------------------------------
CACHE_STORE=redis
# CACHE_PREFIX=omnyrestore_

# -----------------------------------------------------------------------------
# FILESYSTEM — S3 Compatible Storage
# -----------------------------------------------------------------------------
# Local disk is acceptable for development only.
# In production, use S3 (or Cloudflare R2, Scaleway Object Storage).
FILESYSTEM_DISK=local           # local | s3

# Default disk for originals/retouched photos
MEDIA_DISK=s3

# Default disk for generated ZIP deliveries
DELIVERY_DISK=s3

# -----------------------------------------------------------------------------
# REDIS — Session, Cache, Queues
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# EMAIL — Resend (Transactional)
# -----------------------------------------------------------------------------
# Use Resend for transactional emails (order notifications, download links)
# https://resend.com — free tier: 100 emails/day
MAIL_MAILER=resend              # resend | smtp | log (for local dev)
MAIL_FROM_ADDRESS="contact@omnyrestore.fr"
MAIL_FROM_NAME="OmnyRestore"

RESEND_API_KEY=re_xxxxxxxxxxxx

# Local dev: use 'log' mailer to see emails in storage/logs/laravel.log
# MAIL_MAILER=log

# -----------------------------------------------------------------------------
# AWS S3 — File Storage
# -----------------------------------------------------------------------------
# Compatible with: AWS S3, Cloudflare R2, Scaleway Object Storage, MinIO (local)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3    # Paris region
AWS_BUCKET=omnyrestore-media
AWS_USE_PATH_STYLE_ENDPOINT=false   # Set to true for MinIO (local S3)

# Separate bucket for ZIP deliveries (stricter access policy)
AWS_DELIVERY_BUCKET=omnyrestore-deliveries

# For Cloudflare R2 (cost-effective alternative to S3):
# AWS_URL=https://<account-id>.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=true

# -----------------------------------------------------------------------------
# STRIPE — Payment Processing
# -----------------------------------------------------------------------------
# Stripe keys — use TEST keys in local/staging, LIVE keys in production only
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_KEY=pk_test_              # Publishable key (safe to expose in frontend)
STRIPE_SECRET=sk_test_           # Secret key — NEVER expose this
STRIPE_WEBHOOK_SECRET=whsec_     # From: stripe listen --forward-to localhost/webhook/stripe

# Cashier configuration
CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=fr_FR

# -----------------------------------------------------------------------------
# OPENAI API — AI Photo Restoration
# -----------------------------------------------------------------------------
# Used in Phase 2 (v1.2.0) for automated restoration via OpenAI Vision API
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_ORGANIZATION=            # Optional: your org ID
OPENAI_MODEL=gpt-4o             # Model for image restoration

# -----------------------------------------------------------------------------
# HORIZON — Queue Dashboard
# -----------------------------------------------------------------------------
# Horizon dashboard is accessible at /horizon (admin only)
# Configure allowed IPs or email-based access in config/horizon.php
HORIZON_DARK_MODE=true

# -----------------------------------------------------------------------------
# VITE — Frontend Build
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_STRIPE_KEY="${STRIPE_KEY}"     # Passed to frontend for Stripe.js initialization
